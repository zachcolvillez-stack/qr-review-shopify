<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <meta name="theme-color" content="#FFFFFF">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {%- if page_description -%}
      <meta name="description" content="{{ page_description | escape }}">
    {%- endif -%}

    {%- render 'meta-tags' -%}

    <link rel="stylesheet" href="{{ 'base.css' | asset_url }}">
    <link rel="preload" as="font" href="https://fonts.gstatic.com/s/inter/v13/UcCo3FwrK3iLTcvneQg7Ca725JhhKnNqk4j1ebLhAm8SrXTc2dNNDw.woff2" type="font/woff2" crossorigin>

    <style>
      :root {
        --color-bg: #FFFFFF;
        --color-surface: #FAFAF7;
        --color-ink: #0A0A0A;
        --color-muted: #6B7280;
        --color-accent: #0A0A0A;
        --color-border: #ECECEC;
        --radius-sm: 8px;
        --radius-md: 12px;
        --radius-lg: 16px;
        --container: 1200px;
        --container-narrow: 920px;
        --font-body: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        --font-heading: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        --shadow-sm: 0 1px 2px rgba(0,0,0,0.04);
        --shadow-md: 0 4px 24px rgba(0,0,0,0.06);
      }
    </style>

    {{ content_for_header }}
  </head>

  <body class="template-{{ template | replace: '.', '-' | handleize }}">
    <a href="#MainContent" class="skip-to-content">Skip to content</a>

    {% sections 'header-group' %}

    <main id="MainContent" role="main">
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    <script src="{{ 'global.js' | asset_url }}" defer></script>
  </body>
</html>
