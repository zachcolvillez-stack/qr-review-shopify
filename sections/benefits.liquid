<section class="section">
  <div class="container">
    <div class="section-header fade-in">
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p>{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="benefits">
      {%- for block in section.blocks -%}
        <div class="benefit fade-in" {{ block.shopify_attributes }}>
          <div class="benefit__icon">
            {%- case block.settings.icon -%}
              {%- when 'star' -%}
                <svg width="22" height="22" viewBox="0 0 22 22" fill="currentColor"><path d="M11 1.7l2.9 6.1 6.6.7-4.9 4.6 1.4 6.6L11 16.5l-6 3.2 1.4-6.6L1.5 8.5l6.6-.7z"/></svg>
              {%- when 'bolt' -%}
                <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"><path d="M12 1L3 13h7l-1 8 9-12h-7z"/></svg>
              {%- when 'check' -%}
                <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11l5 5L19 6"/></svg>
              {%- when 'sparkle' -%}
                <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M11 2v6M11 14v6M2 11h6M14 11h6"/></svg>
              {%- else -%}
                <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="8"/></svg>
            {%- endcase -%}
          </div>
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.body }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Benefits",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Why businesses choose us" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Built for real-world businesses" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Not a tech experiment. Just simple, premium tools that help local businesses grow." }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "star", "label": "Star" },
            { "value": "bolt", "label": "Bolt" },
            { "value": "check", "label": "Check" },
            { "value": "sparkle", "label": "Sparkle" }
          ],
          "default": "star"
        },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "textarea", "id": "body", "label": "Body" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Benefits",
      "blocks": [
        { "type": "benefit", "settings": { "icon": "star", "title": "More reviews, faster", "body": "Customers scan and review in under 30 seconds." } },
        { "type": "benefit", "settings": { "icon": "bolt", "title": "Set and forget", "body": "One-time setup. Works forever, no apps required." } },
        { "type": "benefit", "settings": { "icon": "sparkle", "title": "Looks the part", "body": "Designed to match a real brand, not a printout." } },
        { "type": "benefit", "settings": { "icon": "check", "title": "Made in Australia", "body": "Printed in Perth. Shipped nationwide in 2-4 days." } }
      ]
    }
  ]
}
{% endschema %}
