<section class="section">
  <div class="container container--narrow">
    <div class="section-header fade-in">
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p>{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="faq fade-in">
      {%- for block in section.blocks -%}
        <details class="faq__item" {{ block.shopify_attributes }}>
          <summary class="faq__summary">{{ block.settings.question }}</summary>
          <div class="faq__body">{{ block.settings.answer }}</div>
        </details>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "FAQ" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Common questions" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" }
  ],
  "blocks": [
    {
      "type": "qa",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question" },
        { "type": "textarea", "id": "answer", "label": "Answer" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "qa", "settings": { "question": "How do I send my Google review link?", "answer": "After you order, we'll email a short form. Paste your Google Business review URL — done. Takes about 60 seconds." } },
        { "type": "qa", "settings": { "question": "How long does setup take?", "answer": "We design your QR code, send a proof, and dispatch within 48 hours of approval. Most orders arrive within 4 business days." } },
        { "type": "qa", "settings": { "question": "Can I add my logo?", "answer": "Yes — free, on all cards and most sticker sizes. Just upload it during checkout or email it to us afterwards." } },
        { "type": "qa", "settings": { "question": "Do you ship Australia-wide?", "answer": "Yes. 2-4 business days via Australia Post tracked. Free shipping on all orders." } },
        { "type": "qa", "settings": { "question": "Are the QR codes permanent?", "answer": "Yes. They link directly to your Google review page and never expire. No subscriptions, no app required." } }
      ]
    }
  ]
}
{% endschema %}
