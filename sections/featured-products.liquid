<section class="section section--alt">
  <div class="container">
    <div class="section-header fade-in">
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p>{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="product-grid">
      {%- for block in section.blocks -%}
        {%- assign product = all_products[block.settings.product] -%}
        <a href="{%- if product != blank -%}{{ product.url }}{%- else -%}#{%- endif -%}" class="product-card fade-in" {{ block.shopify_attributes }}>
          <div class="product-card__media">
            {%- if product != blank and product.featured_image != blank -%}
              {{ product.featured_image | image_url: width: 800 | image_tag:
                loading: 'lazy',
                widths: '400, 600, 800',
                sizes: '(min-width: 768px) 50vw, 100vw',
                alt: product.featured_image.alt | default: product.title
              }}
            {%- elsif block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 800 | image_tag:
                loading: 'lazy',
                widths: '400, 600, 800',
                sizes: '(min-width: 768px) 50vw, 100vw',
                alt: block.settings.title
              }}
            {%- else -%}
              <div style="display:flex;align-items:center;justify-content:center;height:100%;color:var(--color-muted);font-size:0.85rem;">Product image</div>
            {%- endif -%}
          </div>
          <div class="product-card__body">
            <h3 class="product-card__title">
              {{ block.settings.title | default: product.title | default: 'Product' }}
            </h3>
            <p class="product-card__desc">{{ block.settings.description }}</p>
            <div class="product-card__row">
              <span class="product-card__price">
                {%- if product != blank -%}
                  From {{ product.price_min | money }}<small>{{ block.settings.price_unit }}</small>
                {%- else -%}
                  {{ block.settings.price_fallback }}<small>{{ block.settings.price_unit }}</small>
                {%- endif -%}
              </span>
              <span class="btn btn--secondary">Shop now &rarr;</span>
            </div>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured products",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Two products. Both designed to get you more reviews." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Pick the format that fits how customers interact with your business." }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" },
        { "type": "image_picker", "id": "image", "label": "Fallback image" },
        { "type": "text", "id": "title", "label": "Title override" },
        { "type": "textarea", "id": "description", "label": "Short description" },
        { "type": "text", "id": "price_fallback", "label": "Fallback price", "default": "From $29" },
        { "type": "text", "id": "price_unit", "label": "Price unit (e.g. /10)", "default": " for 10" }
      ]
    }
  ],
  "max_blocks": 2,
  "presets": [
    {
      "name": "Featured products",
      "blocks": [
        {
          "type": "product",
          "settings": {
            "title": "QR Review Cards",
            "description": "Premium 350gsm matte cards. Sit on counters and tables. Optional logo and business name.",
            "price_fallback": "From $29",
            "price_unit": " for 10"
          }
        },
        {
          "type": "product",
          "settings": {
            "title": "QR Review Stickers",
            "description": "Waterproof vinyl. Stick on windows, EFTPOS machines, menus, and receipts.",
            "price_fallback": "From $19",
            "price_unit": " for 25"
          }
        }
      ]
    }
  ]
}
{% endschema %}
