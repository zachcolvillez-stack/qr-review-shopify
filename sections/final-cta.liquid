<section class="final-cta fade-in">
  <div class="container container--narrow">
    {%- if section.settings.eyebrow != blank -%}
      <span class="eyebrow" style="color: rgba(255,255,255,0.6);">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.body }}</p>
    {%- if section.settings.cta_text != blank -%}
      <a href="{{ section.settings.cta_link }}" class="btn btn--primary btn--lg">
        {{ section.settings.cta_text }}
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7h8M7 3l4 4-4 4"/></svg>
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Final CTA",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Ready to start?" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Start getting more reviews this week." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Order today. Ships within 48 hours, free across Australia." },
    { "type": "text", "id": "cta_text", "label": "CTA text", "default": "Shop now" },
    { "type": "url", "id": "cta_link", "label": "CTA link" }
  ],
  "presets": [{ "name": "Final CTA" }]
}
{% endschema %}
