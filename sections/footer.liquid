<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      <div class="footer__col">
        <div class="footer__brand">{{ section.settings.brand_name | default: shop.name }}</div>
        <p>{{ section.settings.tagline }}</p>
      </div>

      {%- for block in section.blocks -%}
        {%- if block.type == 'menu' -%}
          <div class="footer__col" {{ block.shopify_attributes }}>
            <h4>{{ block.settings.heading }}</h4>
            <ul>
              {%- for link in linklists[block.settings.menu].links -%}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="footer__bottom">
      <span>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</span>
      <span>{{ section.settings.legal_line }}</span>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "brand_name", "label": "Brand name", "default": "QR Review Co." },
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "Premium QR review cards and stickers. Designed and printed in Australia." },
    { "type": "text", "id": "legal_line", "label": "Legal line", "default": "ABN 00 000 000 000 · Made in Perth" }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu", "default": "footer" }
      ]
    }
  ],
  "max_blocks": 4
}
{% endschema %}
