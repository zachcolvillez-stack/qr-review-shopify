<section class="hero" data-hero>
  <div class="container">
    <div class="hero__grid">
      <div class="hero__content fade-in">
        {%- if section.settings.eyebrow != blank -%}
          <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        <h1 class="hero__title">{{ section.settings.heading }}</h1>
        <p class="hero__subtitle">{{ section.settings.subheading }}</p>

        <div class="hero__ctas">
          {%- if section.settings.cta_primary_text != blank -%}
            <a href="{{ section.settings.cta_primary_link }}" class="btn btn--primary btn--lg">
              {{ section.settings.cta_primary_text }}
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7h8M7 3l4 4-4 4"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.cta_secondary_text != blank -%}
            <a href="{{ section.settings.cta_secondary_link }}" class="btn btn--ghost btn--lg">
              {{ section.settings.cta_secondary_text }}
            </a>
          {%- endif -%}
        </div>

        <div class="hero__trust">
          {%- for block in section.blocks -%}
            {%- if block.type == 'trust' -%}
              <span {{ block.shopify_attributes }}>
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11.5 4L5.5 10 2.5 7"/></svg>
                {{ block.settings.label }}
              </span>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

      <div class="hero__media fade-in">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1200 | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            widths: '400, 600, 900, 1200',
            sizes: '(min-width: 900px) 50vw, 100vw',
            alt: section.settings.image.alt | default: section.settings.heading
          }}
        {%- else -%}
          <div style="display:flex;align-items:center;justify-content:center;height:100%;color:var(--color-muted);font-size:0.9rem;">
            Upload product hero image
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<div class="sticky-cta" data-sticky-cta>
  <a href="{{ section.settings.cta_primary_link }}" class="btn btn--primary btn--lg">
    {{ section.settings.cta_primary_text }}
  </a>
</div>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Trusted by 200+ Australian businesses" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "More Google reviews. Without asking." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Premium QR cards and stickers that turn every customer into a 5-star review. Designed for cafes, tradies, salons, and local businesses across Australia." },
    { "type": "text", "id": "cta_primary_text", "label": "Primary CTA text", "default": "Shop QR cards" },
    { "type": "url", "id": "cta_primary_link", "label": "Primary CTA link" },
    { "type": "text", "id": "cta_secondary_text", "label": "Secondary CTA text", "default": "See how it works" },
    { "type": "url", "id": "cta_secondary_link", "label": "Secondary CTA link" },
    { "type": "image_picker", "id": "image", "label": "Hero image" }
  ],
  "blocks": [
    {
      "type": "trust",
      "name": "Trust line",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Free shipping" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Hero",
      "blocks": [
        { "type": "trust", "settings": { "label": "Free shipping" } },
        { "type": "trust", "settings": { "label": "48hr dispatch" } },
        { "type": "trust", "settings": { "label": "Made in Australia" } }
      ]
    }
  ]
}
{% endschema %}
