<section class="section section--tight">
  <div class="container container--narrow">
    <div class="section-header" style="text-align:left;margin-bottom:32px;">
      <h1>{{ page.title }}</h1>
    </div>
    <div class="rte">{{ page.content }}</div>
  </div>
</section>

<style>
  .rte { font-size: 1.05rem; line-height: 1.75; color: var(--color-ink); }
  .rte p, .rte ul, .rte ol { margin: 0 0 1.25em; }
  .rte h2 { margin: 2em 0 0.6em; font-size: 1.5rem; }
  .rte h3 { margin: 1.6em 0 0.5em; font-size: 1.2rem; }
  .rte a { text-decoration: underline; }
  .rte ul, .rte ol { padding-left: 1.25em; }
</style>

{% schema %}
{ "name": "Page", "settings": [] }
{% endschema %}
